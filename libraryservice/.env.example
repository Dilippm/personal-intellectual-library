# Database Configuration
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=personal_library
DB_HOST=postgres

# Database URL for Prisma (only needed in backend .env)
DATABASE_URL=postgresql://postgres:postgres@localhost:5434/personal_library

# Backend (when running outside Docker)
NODE_ENV=development
PORT=3000

# Frontend
VITE_API_URL=http://localhost:5173
